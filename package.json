{
  "name": "tabloop",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsc && WATCH=true TARGET=chrome vite build",
    "dev:firefox": "tsc && WATCH=true TARGET=firefox vite build",
    "typecheck": "tsc --noEmit",
    "build": "npm run build:chrome && npm run build:firefox",
    "build:chrome": "tsc && TARGET=chrome vite build",
    "build:firefox": "tsc && TARGET=firefox vite build",
    "preview": "vite preview",
    "test": "node --test test/*.test.ts"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.43",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vite-plugin-web-extension": "^4.5.1"
  }
}

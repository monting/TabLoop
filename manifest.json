{
  "manifest_version": 3,
  "name": "TabLoop",
  "version": "1.0.0",
  "description": "Limit your open tabs and force yourself to deal with the backlog.",
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "action": {
    "default_popup": "index.html"
  },
  "options_ui": {
    "page": "src/options.html",
    "open_in_tab": true
  },
  "{{chrome}}.background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "{{firefox}}.background": {
    "scripts": ["src/background.ts"],
    "type": "module"
  },
  "permissions": [
    "storage",
    "tabs",
    "{{chrome}}.favicon"
  ],
  "{{chrome}}.web_accessible_resources": [
    {
      "resources": ["_favicon/*"],
      "matches": ["<all_urls>"],
      "extension_ids": ["*"]
    }
  ],
  "{{firefox}}.browser_specific_settings": {
    "gecko": {
      "id": "tabloop@montl.dev",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
